import java.io.*;
import java.math.*;
import java.security.*;
import java.text.*;
import java.util.*;
import java.util.concurrent.*;
import java.util.function.*;
import java.util.regex.*;
import java.util.stream.*;
import static java.util.stream.Collectors.joining;
import static java.util.stream.Collectors.toList;

class Result {

 public static List<Integer> circularPalindromes(String s) {
    int n = s.length();
    String t = s + s;
    List<Integer> result = new ArrayList<>();

    for (int start = 0; start < n; start++) {
        int maxLen = 1;

        for (int center = start; center < start + n; center++) {

            // odd length palindrome
            maxLen = Math.max(maxLen,
                    expand(t, center, center, start, start + n - 1));

            // even length palindrome
            maxLen = Math.max(maxLen,
                    expand(t, center, center + 1, start, start + n - 1));
        }

        result.add(maxLen);
    }

    return result;
}

private static int expand(String s, int left, int right, int low, int high) {
    while (left >= low && right <= high && s.charAt(left) == s.charAt(right)) {
        left--;
        right++;
    }
    return right - left - 1;
}
}

public class Solution {
    public static void main(String[] args) throws IOException {
        BufferedReader bufferedReader = new BufferedReader(new InputStreamReader(System.in));
        BufferedWriter bufferedWriter = new BufferedWriter(new FileWriter(System.getenv("OUTPUT_PATH")));

        int n = Integer.parseInt(bufferedReader.readLine().trim());

        String s = bufferedReader.readLine();

        List<Integer> result = Result.circularPalindromes(s);

        bufferedWriter.write(
            result.stream()
                .map(Object::toString)
                .collect(joining("\n"))
            + "\n"
        );

        bufferedReader.close();
        bufferedWriter.close();
    }
}
